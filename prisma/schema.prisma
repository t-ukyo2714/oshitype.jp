generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id    Int    @id @default(autoincrement())
  text  String @unique
  axis  String @default("L-K") // L-K, S-G, O-E, N-T
  order Int    @default(0)
}

model ResultContent {
  code      String @id
  title     String
  feature   Json
  aruaru    Json
  strength  Json
  caution   Json
  shareText   String
  imageUrl    String?
  ogpImageUrl String?
}

model AxisDefinition {
  code  String @id
  label String
  sub   String
  desc  String
}

model SubmissionLog {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  oshiGroup   String
  memberMode  String
  oshiMember  String?
  ageBand     String
  resultCode  String
  lpct        Int
  spct        Int
  opct        Int
  npct        Int
  answersJson Json?
  userAgent   String?
}
